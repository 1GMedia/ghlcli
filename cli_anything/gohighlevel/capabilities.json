{
  "schema": 1,
  "project": "ghlcli",
  "commands": [
    {
      "name": "doctor",
      "command": "ghlcli doctor",
      "provider": "local-diagnostics",
      "auth": "none",
      "stability": "stable",
      "mutates": false,
      "endpoint": "local environment"
    },
    {
      "name": "capabilities.list",
      "command": "ghlcli capabilities list",
