# GoHighLevel public API
# Create a Private Integration Token in GHL:
# Settings -> Private Integrations -> Create New
GHL_API_KEY=YOUR_PRIVATE_INTEGRATION_TOKEN

# Your GHL location/sub-account ID.
GHL_LOCATION_ID=YOUR_LOCATION_ID

# Optional: only needed for experimental internal workflow create/update commands.
# See docs/get-firebase-token.md.
GHL_FIREBASE_REFRESH_TOKEN=

# Optional: required when using GHL_FIREBASE_REFRESH_TOKEN.
# This is the Firebase Web API key used by the GHL web app.
GHL_FIREBASE_API_KEY=

# Optional: direct short-lived Firebase ID token. Prefer refresh token above.
GHL_FIREBASE_TOKEN=
